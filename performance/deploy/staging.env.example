# JobFlow staging/performance deployment env template
# 실제 secret 값은 이 파일에 넣지 않는다.
# 서버에서는 이 파일을 복사해서 .env로 만들고, 값은 서버에서만 채운다.

# -------------------------------------------------------------------
# Spring profiles
# -------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=local,oauth2-github

# -------------------------------------------------------------------
# Performance profile
# -------------------------------------------------------------------
# k6 baseline 측정은 운영/수집 DB가 아니라 performance DB/profile 기준으로 실행한다.
# docker-compose.performance.yml은 PERF_SPRING_PROFILES_ACTIVE를 사용하므로,
# 일반 SPRING_PROFILES_ACTIVE 값이 performance profile을 덮어쓰지 않는다.
PERF_SPRING_PROFILES_ACTIVE=local,performance

# 기존 jobflow-mysql 컨테이너 안에 별도 database/schema로 만든다.
# 실제 서버에서는 MYSQL_PASSWORD와 같은 DB user password를 넣거나,
# 별도 성능 DB user를 만들었다면 그 값을 넣는다.
PERF_DB_NAME=jobflow_perf
PERF_DB_USER=jobflow
PERF_DB_PASSWORD=change-me

# Performance profile 전용 Elasticsearch alias/index.
# 운영 검색 alias(jobflow-jobs)와 절대 섞지 않는다.
ELASTICSEARCH_JOBS_ALIAS=jobflow-jobs-performance
ELASTICSEARCH_JOBS_INDEX=jobflow-jobs-performance-v1
# 200k performance index를 최초 준비하거나 의도적으로 재생성할 때만 true로 바꾼다.
# 일반적인 stress test 반복 실행에서는 기존 index를 재사용해야 하므로 false를 기본값으로 둔다.
ELASTICSEARCH_REINDEX_ON_STARTUP=false
ELASTICSEARCH_REINDEX_BATCH_SIZE=500

# k6 smoke/pre-k6 smoke 기준.
EXPECTED_MIN_RESULT_COUNT=1

# Redis cache stress test에서만 true로 켠다.
# no-cache baseline에서는 false를 유지한다.
PERF_CACHE_ENABLED=false

# 성능 DB seed script용 값.
# RESET_PERF_DB=true는 성능 DB를 의도적으로 재생성할 때만 사용한다.
MYSQL_CONTAINER=jobflow-mysql
MYSQL_ROOT_USER=root
RESET_PERF_DB=false

# -------------------------------------------------------------------
# Ports
# -------------------------------------------------------------------
GATEWAY_PORT=8081
GATEWAY_RATE_LIMIT_ENABLED=true
GATEWAY_RATE_LIMIT_REQUESTS_PER_MINUTE=100
PERF_GATEWAY_RATE_LIMIT_ENABLED=false
PERF_GATEWAY_RATE_LIMIT_REQUESTS_PER_MINUTE=100000

# -------------------------------------------------------------------
# Database
# -------------------------------------------------------------------
MYSQL_DATABASE=jobflow
MYSQL_USER=jobflow
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-me

# -------------------------------------------------------------------
# Redis
# -------------------------------------------------------------------
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# -------------------------------------------------------------------
# Elasticsearch
# -------------------------------------------------------------------
ELASTICSEARCH_URL=http://elasticsearch:9200
HOST_ELASTICSEARCH_URL=http://localhost:9200
ES_JAVA_OPTS="-Xms1g -Xmx1g"

# w8-5 ES no-cache stress test overrides.
# These values are consumed by docker-compose.performance.yml.
PERF_ELASTICSEARCH_MEMORY_LIMIT=3g
PERF_ES_JAVA_OPTS="-Xms2g -Xmx2g"
PERF_MANAGEMENT_HEALTH_ELASTICSEARCH_ENABLED=false

# -------------------------------------------------------------------
# Backend saturation tuning
# -------------------------------------------------------------------
# w8-9 saturation workload에서 1000/2000/3000 RPS를 단계적으로 시도할 때만 조정한다.
# cache-hit 중심 /jobs/search에서는 DB pool보다 Tomcat connection/thread queue와 k6 generator 한계를 먼저 본다.
PERF_BACKEND_MEMORY_LIMIT=2g
PERF_BACKEND_JAVA_TOOL_OPTIONS="-XX:MaxRAMPercentage=75.0"
PERF_SERVER_TOMCAT_THREADS_MAX=200
PERF_SERVER_TOMCAT_THREADS_MIN_SPARE=20
PERF_SERVER_TOMCAT_ACCEPT_COUNT=100
PERF_SERVER_TOMCAT_MAX_CONNECTIONS=8192
PERF_HIKARI_MAXIMUM_POOL_SIZE=20
PERF_HIKARI_MINIMUM_IDLE=5

# -------------------------------------------------------------------
# Kafka
# -------------------------------------------------------------------
# Container-internal broker address used by Spring services.
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
PERF_KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# Host-side broker address used by local CLI checks.
KAFKA_BOOTSTRAP_SERVERS=localhost:19092

# Single-node performance stack topic defaults.
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1

# Outbox Relay Kafka smoke defaults.
OUTBOX_SMOKE_TOPIC=job.created
OUTBOX_SMOKE_WAIT_SECONDS=30
KAFKA_CONSUMER_TIMEOUT_MS=10000

# Performance stack에서는 실제 Mailgun 대량 발송을 하지 않는다.
PERF_NOTIFICATION_EMAIL_PROVIDER=mock

# -------------------------------------------------------------------
# Observability
# -------------------------------------------------------------------
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
TRACING_SAMPLING_PROBABILITY=1.0

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# -------------------------------------------------------------------
# Log pipeline
# -------------------------------------------------------------------
GATEWAY_SECURITY_EVENTS_ENABLED=true
GATEWAY_SECURITY_EVENTS_TOPIC=security.events
GATEWAY_SECURITY_EVENTS_ENVIRONMENT=staging-performance

LOGSTASH_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
LOGSTASH_SECURITY_EVENTS_TOPIC=security.events
LOGSTASH_SECURITY_EVENTS_GROUP_ID=jobflow-logstash-security-events
LOGSTASH_SECURITY_EVENTS_AUTO_OFFSET_RESET=latest
LOGSTASH_ELASTICSEARCH_URL=http://elasticsearch:9200
LOGSTASH_SECURITY_EVENTS_INDEX=jobflow-security-events

# -------------------------------------------------------------------
# Security
# -------------------------------------------------------------------
# JWT_SECRET은 최소 32바이트 이상이어야 한다.
JWT_SECRET=change-me-at-least-32-bytes

# OAuth provider access token 암호화 key.
# 실제 값은 서버에서만 보관한다.
OAUTH2_PROVIDER_TOKEN_ENCRYPTION_KEY=change-me

# -------------------------------------------------------------------
# GitHub OAuth
# -------------------------------------------------------------------
# GitHub OAuth App에서 발급받은 Client ID.
GITHUB_CLIENT_ID=change-me

# GitHub OAuth App에서 발급받은 Client Secret.
# 절대 GitHub/PR/문서에 올리지 않는다.
GITHUB_CLIENT_SECRET=change-me

# GitHub OAuth App callback URL과 정확히 일치해야 한다.
# staging 예시:
# GITHUB_OAUTH_REDIRECT_URI=https://api.example.com/api/login/oauth2/code/github
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8081/api/login/oauth2/code/github

# OAuth 성공/실패 후 frontend로 돌아갈 주소.
# staging 예시:
# OAUTH2_SUCCESS_REDIRECT_URI=https://app.example.com/oauth2/success
# OAUTH2_FAILURE_REDIRECT_URI=https://app.example.com/oauth2/failure
OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:5173/oauth2/success
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:5173/oauth2/failure

# -------------------------------------------------------------------
# Demo/Admin bootstrap
# -------------------------------------------------------------------
DEMO_LOGIN_ENABLED=false

ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NAME=Admin

# -------------------------------------------------------------------
# Runtime tuning
# -------------------------------------------------------------------
HIKARI_MAXIMUM_POOL_SIZE=20
HIKARI_MINIMUM_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

SHUTDOWN_PHASE_TIMEOUT=30s

BACKEND_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0
GATEWAY_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0

# -------------------------------------------------------------------
# Container memory limits
# -------------------------------------------------------------------
MYSQL_MEMORY_LIMIT=1g
REDIS_MEMORY_LIMIT=256m
ELASTICSEARCH_MEMORY_LIMIT=1g
ZOOKEEPER_MEMORY_LIMIT=512m
KAFKA_MEMORY_LIMIT=1g
BACKEND_MEMORY_LIMIT=1g
GATEWAY_MEMORY_LIMIT=512m
PROMETHEUS_MEMORY_LIMIT=512m
GRAFANA_MEMORY_LIMIT=512m
ZIPKIN_MEMORY_LIMIT=512m
LOGSTASH_MEMORY_LIMIT=1g
KIBANA_MEMORY_LIMIT=1g

# -------------------------------------------------------------------
# Schedulers
# -------------------------------------------------------------------
# staging 첫 배포에서는 의도치 않은 배치 부하를 막기 위해 기본 false 권장.
SKILL_TREND_AGGREGATION_SCHEDULER_ENABLED=false
DEADLINE_REMINDER_SCHEDULER_ENABLED=false
