# JobFlow performance dataset profile
# Copy this file to performance/dataset/performance.env when you want local overrides.
# Do not commit performance.env.

MYSQL_CONTAINER=jobflow-mysql
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASSWORD=root

PERF_DB_NAME=jobflow_perf
PERF_DB_USER=jobflow
PERF_DB_PASSWORD=jobflow

# Smoke scale: 1000~10000
# Baseline scale before k6: 500000
PERF_JOB_COUNT=1000

# Set true only when you intentionally want to recreate the performance DB.
RESET_PERF_DB=false
