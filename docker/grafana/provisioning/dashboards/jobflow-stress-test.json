{
  "uid": "jobflow-stress-test",
  "title": "JobFlow Stress Test Dashboard",
  "tags": ["jobflow", "stress-test", "performance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "/jobs/search RPS",
      "description": "/jobs/search 엔드포인트의 초당 요청 수. 3단계(MySQL → ES → ES+Redis) 비교 기준 패널.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"jobflow-backend\", uri=~\".*/jobs/search.*\"}[1m])) by (uri, status)",
          "legendFormat": "{{uri}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "/jobs/search p95 Latency",
      "description": "/jobs/search p95 latency. MySQL → ES → ES+Redis 단계별 응답 시간 비교.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"jobflow-backend\", uri=~\".*/jobs/search.*\"}[1m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"jobflow-backend\", uri=~\".*/jobs/search.*\"}[1m])) by (le, uri))",
          "legendFormat": "p99 {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate",
      "description": "전체 HTTP 요청 중 4xx/5xx 비율. 부하 테스트 stop rule 기준(>50%) 확인용.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate(http_server_requests_seconds_count{application=\"jobflow-backend\", status=~\"4..|5..\"}[1m])) or vector(0)) / clamp_min((sum(rate(http_server_requests_seconds_count{application=\"jobflow-backend\"}[1m])) or vector(0)), 0.001)",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Cache Hit Rate",
      "description": "jobSearch, gapAnalysis, jdMatch, jobRecommendation cache hit/miss 추이.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (cache) (rate(cache_gets_total{application=\"jobflow-backend\", result=\"hit\", cache=~\"jobSearch|gapAnalysis|jdMatch|jobRecommendation\"}[1m])) / clamp_min(sum by (cache) (rate(cache_gets_total{application=\"jobflow-backend\", cache=~\"jobSearch|gapAnalysis|jdMatch|jobRecommendation\"}[1m])), 0.001)",
          "legendFormat": "{{cache}} hit rate"
        },
        {
          "refId": "B",
          "expr": "sum by (cache) (rate(cache_gets_total{application=\"jobflow-backend\", result=\"hit\", cache=~\"jobSearch|gapAnalysis|jdMatch|jobRecommendation\"}[1m]))",
          "legendFormat": "{{cache}} hits/s"
        },
        {
          "refId": "C",
          "expr": "sum by (cache) (rate(cache_gets_total{application=\"jobflow-backend\", result=\"miss\", cache=~\"jobSearch|gapAnalysis|jdMatch|jobRecommendation\"}[1m]))",
          "legendFormat": "{{cache}} misses/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".* hit rate$" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "min", "value": 0 },
              { "id": "max", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* hits/s$" },
            "properties": [{ "id": "unit", "value": "reqps" }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* misses/s$" },
            "properties": [{ "id": "unit", "value": "reqps" }]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "JVM Heap Used",
      "description": "JVM heap 메모리 사용량. 500VU 구간에서 GC 압박과 메모리 증가 패턴 확인.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{application=\"jobflow-backend\", area=\"heap\"}) by (id)",
          "legendFormat": "heap {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HikariCP Active Connections",
      "description": "DB connection pool 사용 현황. active가 max에 가까워지면 DB 병목. OS/WAS 튜닝 전후 비교.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active{application=\"jobflow-backend\"}",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_pending{application=\"jobflow-backend\"}",
          "legendFormat": "pending"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections_idle{application=\"jobflow-backend\"}",
          "legendFormat": "idle"
        },
        {
          "refId": "D",
          "expr": "hikaricp_connections_max{application=\"jobflow-backend\"}",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash" } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "ES Indexing Rate",
      "description": "Kafka consumer가 Elasticsearch에 색인하는 속도. consumer가 붙었을 때 색인 처리량 확인.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"jobflow-backend\", uri=~\".*/search/index.*\"}[1m])) or vector(0)",
          "legendFormat": "index requests/s"
        },
        {
          "refId": "B",
          "expr": "sum(rate(http_client_requests_seconds_count{application=\"jobflow-backend\", uri=~\".*_doc.*\"}[1m])) or vector(0)",
          "legendFormat": "es doc writes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "description": "Kafka consumer가 처리하지 못한 미처리 메시지 수. lag이 쌓이면 consumer 처리 병목.",
      "datasource": {
        "type": "prometheus",
        "uid": "Prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kafka_consumer_fetch_manager_records_lag{application=\"jobflow-backend\"}) by (topic)",
          "legendFormat": "lag {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ]
}
