# Gateway base URL for local frontend development.
# Vite dev server runs on 5173, while the API enters through Spring Cloud Gateway on 8081.
VITE_API_BASE_URL=http://localhost:8081/api

# Local smoke project id owned by the logged-in user.
# This is a non-secret local selector. Do not put JWT tokens or OAuth secrets in this file.
VITE_DEFAULT_USER_PROJECT_ID=2
