# API base path for local frontend development.
# Vite proxies /api to Spring Cloud Gateway on 8081.
VITE_API_BASE_URL=/api

# Local smoke project id owned by the logged-in user.
# This is a non-secret local selector used by project inventory, JD match, gap analysis, and recommendation APIs.
# Do not put JWT tokens, OAuth secrets, real personal credentials, or provider tokens in this file.
VITE_DEFAULT_USER_PROJECT_ID=

# VITE_* values are exposed to the browser bundle.
# Do not add demo account passwords, JWT tokens, OAuth secrets, or provider tokens here.
