# API base path for local frontend development.
# Vite proxies /api to Spring Cloud Gateway on 8081.
VITE_API_BASE_URL=/api

# Local smoke project id owned by the logged-in user.
# This is a non-secret local selector. Do not put JWT tokens or OAuth secrets in this file.
VITE_DEFAULT_USER_PROJECT_ID=

# Optional local demo login for local-only development.
# VITE_* values are exposed to the browser bundle, so never use real personal credentials here.
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD=
VITE_DEMO_PROJECT_ID=
