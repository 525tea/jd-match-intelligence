# Copy this file to .env for local Docker Compose runs.
# Do not commit .env. Keep real client secrets and encryption keys local only.

# Use "local" for normal compose runs.
# Use "local,oauth2-github" when testing GitHub OAuth with the Docker backend.
SPRING_PROFILES_ACTIVE=local

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:8081/api/login/oauth2/code/github
OAUTH2_PROVIDER_TOKEN_ENCRYPTION_KEY=

OAUTH2_SUCCESS_REDIRECT_URI=http://localhost:3000/oauth2/success
OAUTH2_FAILURE_REDIRECT_URI=http://localhost:3000/oauth2/failure

# Kafka local compose defaults.
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PARTITIONS=3
KAFKA_TOPIC_REPLICATION_FACTOR=1
ZOOKEEPER_MEMORY_LIMIT=512m
KAFKA_MEMORY_LIMIT=1g
